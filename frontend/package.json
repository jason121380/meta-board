{
  "name": "metadash-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LURE Meta Platform — React frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src && pnpm lint:no-ad-class",
    "lint:fix": "biome check --write src",
    "lint:no-ad-class": "node scripts/check-no-ad-class.mjs",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "gen:api": "openapi-typescript http://localhost:8001/openapi.json -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@tanstack/react-query": "^5.62.0",
    "chart.js": "4.4.0",
    "chartjs-plugin-datalabels": "2.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "1.56.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0"
}
